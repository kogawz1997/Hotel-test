{
  "name": "hotel-pms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "start": "next start",
    "lint": "echo \"No ESLint config yet. Add eslint-config-next before enforcing lint.\"",
    "type-check": "tsc --noEmit",
    "check:prod-env": "node scripts/check-production-env.mjs",
    "verify": "npm run smoke:prod && npm run check:final-readiness && npm run type-check && npm run build && npm run check:prod-env",
    "smoke:prod": "node scripts/production-smoke.mjs",
    "check:final-readiness": "node scripts/final-readiness-check.mjs",
    "build:vercel-test": "USE_MOCK_SERVICES=1 NEXT_PUBLIC_USE_MOCK_SERVICES=1 NEXT_TELEMETRY_DISABLED=1 next build",
    "check:vercel-test": "USE_MOCK_SERVICES=1 NEXT_PUBLIC_USE_MOCK_SERVICES=1 node scripts/vercel-preview-check.mjs",
    "seed:demo": "node scripts/seed-demo.mjs",
    "check:ux": "node scripts/ux-readiness-check.mjs",
    "install:vercel": "npm ci --no-audit --no-fund --progress=false --prefer-offline",
    "build:vercel": "NEXT_TELEMETRY_DISABLED=1 USE_MOCK_SERVICES=1 NEXT_PUBLIC_USE_MOCK_SERVICES=1 next build",
    "check:vercel-install": "node scripts/check-vercel-install-config.mjs",
    "check:root-route": "node scripts/check-root-route.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",

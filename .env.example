# =============================================================================
# Maitri — Hotel Operating System
# =============================================================================
# Copy this file to .env.local and fill in your actual values.
# See docs/SETUP_TODO.md for instructions on getting each credential.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED · Core
# -----------------------------------------------------------------------------

# Supabase — https://supabase.com (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# App URL (production: your custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# CHANNELS · Guest Communication
# -----------------------------------------------------------------------------

# LINE Messaging API — https://developers.line.biz
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# WhatsApp Business API — https://business.facebook.com
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=any_random_string_you_choose

# WeChat (optional, for Chinese guests)
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# SendGrid (transactional email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@yourdomain.com


# -----------------------------------------------------------------------------
# PAYMENTS
# -----------------------------------------------------------------------------

# Omise (Thai payment gateway, PromptPay) — https://omise.co
OMISE_PUBLIC_KEY=pkey_test_...
OMISE_SECRET_KEY=skey_test_...

# Stripe (international, optional)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# CHANNEL MANAGER (OTA)
# -----------------------------------------------------------------------------

# Aggregator: HotelRunner — https://hotelrunner.com
HOTELRUNNER_API_KEY=
HOTELRUNNER_API_SECRET=

# Direct: Booking.com (after Connectivity Partner approval)
BOOKING_COM_USERNAME=
BOOKING_COM_PASSWORD=

# Direct: Agoda YCS
AGODA_API_KEY=

# Direct: Airbnb
AIRBNB_CLIENT_ID=
AIRBNB_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# THAI COMPLIANCE
# -----------------------------------------------------------------------------

# e-Tax Provider (INET / Frank / Leceipt)
ETAX_PROVIDER=inet
ETAX_USERNAME=
ETAX_PASSWORD=
ETAX_CERTIFICATE_PATH=/path/to/cert.p12


# -----------------------------------------------------------------------------
# ACCOUNTING
# -----------------------------------------------------------------------------

# FlowAccount — https://flowaccount.com
FLOWACCOUNT_API_KEY=

# PEAK — https://peakaccount.com
PEAK_API_KEY=

# Production SaaS hardening
# Use unique 32+ character secrets in production. Do not reuse between providers.
WEBHOOK_SHARED_SECRET=change-me-min-32-chars
AGODA_WEBHOOK_TOKEN=change-me-min-32-chars
BOOKING_COM_WEBHOOK_TOKEN=change-me-min-32-chars
OMISE_WEBHOOK_SECRET=change-me-min-32-chars

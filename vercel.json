{
  "framework": "nextjs",
  "buildCommand": "npm run build:vercel",
  "installCommand": "npm ci --no-audit --no-fund --progress=false --prefer-offline",
  "env": {
    "USE_MOCK_SERVICES": "1",
    "NEXT_PUBLIC_USE_MOCK_SERVICES": "1",
    "MOCK_AUTH_USER": "owner",
    "NEXT_PUBLIC_SUPABASE_URL": "https://maitri-demo.supabase.co",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "demo-anon-key-for-vercel-preview-only-000000",
    "SUPABASE_SERVICE_ROLE_KEY": "demo-service-role-key-for-vercel-preview-only-000000",
    "OMISE_PUBLIC_KEY": "pkey_test_maitri_mock_preview",
    "OMISE_SECRET_KEY": "skey_test_maitri_mock_preview",
    "OMISE_WEBHOOK_SECRET": "whsec_maitri_mock_preview",
    "WEBHOOK_SHARED_SECRET": "shared_mock_preview_secret"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
